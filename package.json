{
  "name": "anime-countdown",
  "version": "1.0.0",
  "private": true,
  "description": "Anime release countdown with native notifications",
  "scripts": {
    "dev": "node server.js",
    "cap:init": "npx cap init AnimeCountdown com.animecountdown.app",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build:www && npx cap sync",
    "cap:open:android": "npx cap open android",
    "build:www": "powershell -ExecutionPolicy Bypass -File scripts/build-www.ps1",
    "cap:build": "npm run build:www && npx cap sync && npx cap copy android"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  }
}
